# News Dashboard API Keys

# NewsAPI.org - Get your free API key at https://newsapi.org/register
# Free tier: 100 requests/day, 500 requests/month
VITE_NEWS_API_KEY=your_newsapi_key_here

# OpenWeatherMap - Get your free API key at https://openweathermap.org/api
# Free tier: 60 calls/minute, 1,000,000 calls/month
VITE_WEATHER_API_KEY=your_openweathermap_api_key_here

# Instructions:
# 1. Copy this file to .env in the frontend directory
# 2. Replace the placeholder values with your actual API keys
# 3. Never commit the .env file to version control
