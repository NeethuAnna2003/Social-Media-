# Core Django
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=your-backend-domain.koyeb.app,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://your-backend-domain.koyeb.app,https://your-frontend-domain.vercel.app

# Frontend URL used for password reset links
FRONTEND_URL=https://your-frontend-domain.vercel.app

# CORS
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,http://localhost:5173

# Database (MySQL)
# Option A: Use discrete MySQL values (recommended for MySQL deployments)
DB_ENGINE=django.db.backends.mysql
DB_NAME=connectify_db
DB_USER=your_mysql_user
DB_PASSWORD=your_mysql_password
DB_HOST=your_mysql_host
DB_PORT=3306

# Option B: Use single URL (optional)
# Example: mysql://user:password@host:3306/connectify_db
DATABASE_URL=

# Realtime / Celery (Upstash Redis free)
REDIS_URL=rediss://default:password@host:port
CELERY_BROKER_URL=rediss://default:password@host:port
CELERY_RESULT_BACKEND=rediss://default:password@host:port

# Email (use app password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=you@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# AI and external APIs (fill only what you use)
HUGGINGFACE_API_KEY=
REPLICATE_API_TOKEN=
GEMINI_API_KEY=
ASSEMBLYAI_API_KEY=
